{
  "family": "raheeq_devops",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::124146831274:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "nginx",
      "image": "124146831274.dkr.ecr.eu-north-1.amazonaws.com/dev/nodeimage",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ]
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024"
}
